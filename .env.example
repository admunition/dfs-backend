# App
APP_NAME=DFS Backend API
APP_ENV=production
DEBUG=False

# MongoDB
MONGO_ROOT_USER=your_mongo_user
MONGO_ROOT_PASSWORD=your_mongo_password
MONGODB_URL=mongodb://your_mongo_user:your_mongo_password@mongo:27017
MONGODB_DB_NAME=my_dfs_db

# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS & Trusted Hosts
ALLOWED_ORIGINS=["https://your-app.lovable.app","https://yourdomain.com"]
ALLOWED_HOSTS=["yourdomain.com","your-server-ip"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Request Size (bytes) — 1MB default
MAX_REQUEST_SIZE=1048576

# Supabase JWT (get from Supabase dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# DataForSEO credentials
DATAFORSEO_USERNAME=your-dataforseo-email
DATAFORSEO_PASSWORD=your-dataforseo-password
